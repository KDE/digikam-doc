#: ../../left_sidebar/albums_view.rst:-1
msgid ""
"digiKam, documentation, user manual, photo management, open source, free, "
"learn, easy, album, properties, creating, moving"
msgstr ""
"digiKam, dokumentácia, používateľská príručka, správa fotografií, open "
"source, zadarmo, naučiť sa, jednoducho, album, vlastnosti, vytváranie, "
"presúvanie"

