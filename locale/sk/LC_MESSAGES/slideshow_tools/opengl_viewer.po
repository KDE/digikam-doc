msgid "Toggle scroll-wheel action:"
msgstr "Prepnúť akciu rolovacieho kolieska:"

#: ../../slideshow_tools/opengl_viewer.rst:54
msgid ":kbd:`c` key (either zoom or change image)"
msgstr ":kbd:`c` (buď priblíženie alebo zmena obrázka)"

