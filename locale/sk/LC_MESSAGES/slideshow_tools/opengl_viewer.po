msgid "Previous Item:"
msgstr "Predošlá položka:"

#: ../../slideshow_tools/opengl_viewer.rst:40
msgid ":kbd:`Down` key :kbd:`PgDown` key :kbd:`Right` key Mouse wheel down"
msgstr ":kbd:`Dole` :kbd:`PgDown` :kbd:`Vpravo` Rolovacie koliesko nadol"

#: ../../slideshow_tools/opengl_viewer.rst:43
msgid "Next Item:"
msgstr "Ďalšia položka:"

#: ../../slideshow_tools/opengl_viewer.rst:46
msgid "Quit:"
msgstr "Ukončiť:"

