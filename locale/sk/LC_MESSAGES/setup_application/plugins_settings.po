msgid "Image Loaders Plugins Setup Page"
msgstr "Stránka nastavení doplnkov načítavačov obrázkov"

#: ../../setup_application/plugins_settings.rst:88
msgid "The Image Loaders Plugins Setup Page"
msgstr "Stránka nastavení doplnkov načítavačov obrázkov"

