#: ../../menu_descriptions/menu_batchqueue.rst:-1
msgid "digiKam Batch Queue Manager Menu Descriptions"
msgstr "Popisy ponuky digiKam Batch Queue Manager"

#: ../../menu_descriptions/menu_batchqueue.rst:-1
msgid ""
"digiKam, documentation, user manual, photo management, open source, free, "
"learn, easy, menu, batch queue manager"
msgstr ""
"digiKam, dokumentácia, používateľský manuál, správa fotié, open source, "
"zadarmo, učiť sa, jednoduché, ponuka, správca dávkových frontíkov"

#: ../../menu_descriptions/menu_batchqueue.rst:14
msgid ":ref:`Batch Queue Manager Menu <menu_descriptions>`"
msgstr ":ref:`Ponuka Batch Queue Manager <menu_descriptions>`"

#: ../../menu_descriptions/menu_batchqueue.rst:16
msgid "Contents"
msgstr "Obsah"

#: ../../menu_descriptions/menu_batchqueue.rst:22
msgid "The digiKam Batch Queue Manager Menu"
msgstr "Ponuka digiKam Batch Queue Manager"

#: ../../menu_descriptions/menu_batchqueue.rst:26
msgid "icon_hamburger"
msgstr "icon_hamburger"

#: ../../menu_descriptions/menu_batchqueue.rst:28
msgid ""
"When switching into **Full-Screen Mode** :kbd:`Ctrl+Shift+F`, or when you "
"**Hide Menubar** :kbd:`Ctrl+M`, the main menu will be available on the right "
"side of toolbar with the **Hamburger Button** |icon_hamburger|."
msgstr ""
"Pri prepnutí do režimu **Celá obrazovka** :kbd:`Ctrl+Shift+F`, alebo keď "
"**Skryjete panel ponuky** :kbd:`Ctrl+M`, hlavná ponuka bude dostupná na "
"pravej strane panela nástrojov pomocou **tlačidla Hamburger** |"
"icon_hamburger|."

#: ../../menu_descriptions/menu_batchqueue.rst:31
msgid "The Queues Menu"
msgstr "Ponuka Fronty"

#: ../../menu_descriptions/menu_batchqueue.rst:33
msgid ":menuselection:`Queues --> Run` :kbd:`Ctrl+P`"
msgstr ":menuselection:`Fronty --> Spustiť` :kbd:`Ctrl+P`"

#: ../../menu_descriptions/menu_batchqueue.rst:35
msgid "Run the current selected queue from the **Queues** stack."
msgstr "Spustí aktuálne vybratý front zo zásobníka **Frontíkov**."

#: ../../menu_descriptions/menu_batchqueue.rst:37
msgid ":menuselection:`Queues --> Run All` :kbd:`Ctrl+Alt+P`"
msgstr ":menuselection:`Fronty --> Spustiť všetko` :kbd:`Ctrl+Alt+P`"

#: ../../menu_descriptions/menu_batchqueue.rst:39
msgid "Run all queues from the **Queues** stack."
msgstr "Spustí všetky fronty zo zásobníka **Frontíkov**."

#: ../../menu_descriptions/menu_batchqueue.rst:41
msgid ":menuselection:`Queues --> Stop` :kbd:`Ctrl+S`"
msgstr ":menuselection:`Fronty --> Zastaviť` :kbd:`Ctrl+S`"

#: ../../menu_descriptions/menu_batchqueue.rst:43
msgid "Cancel current execution from the **Queues** stack."
msgstr "Zruší aktuálne vykonávanie zo zásobníka **Frontíkov**."

#: ../../menu_descriptions/menu_batchqueue.rst:45
msgid ":menuselection:`Queues --> New Queue`"
msgstr ":menuselection:`Fronty --> Nový front`"

#: ../../menu_descriptions/menu_batchqueue.rst:47
msgid "Add a new queue in the **Queues** stack."
msgstr "Pridá nový front do zásobníka **Frontíkov**."

#: ../../menu_descriptions/menu_batchqueue.rst:49
msgid ":menuselection:`Queues --> Remove Queue`"
msgstr ":menuselection:`Fronty --> Odstrániť front`"

#: ../../menu_descriptions/menu_batchqueue.rst:51
msgid "Remove the current selected queue from the **Queues** stack."
msgstr "Odstráni aktuálne vybratý front zo zásobníka **Frontíkov**."

#: ../../menu_descriptions/menu_batchqueue.rst:53
msgid ":menuselection:`Queues --> Save Workflow`"
msgstr ":menuselection:`Fronty --> Uložiť pracovný postup`"

#: ../../menu_descriptions/menu_batchqueue.rst:55
msgid "Create a new **Workflow** based the settings of the current queue."
msgstr ""
"Vytvorí nový **Pracovný postup** na základe nastavení aktuálneho frontu."

#: ../../menu_descriptions/menu_batchqueue.rst:57
msgid ":menuselection:`Queues --> Remove Items` :kbd:`Ctrl+K`"
msgstr ":menuselection:`Fronty --> Odstrániť položky` :kbd:`Ctrl+K`"

#: ../../menu_descriptions/menu_batchqueue.rst:59
msgid "Remove selected items from the current queue."
msgstr "Odstráni vybrané položky z aktuálneho frontu."

#: ../../menu_descriptions/menu_batchqueue.rst:61
msgid ":menuselection:`Queues --> Remove processed items`"
msgstr ":menuselection:`Fronty --> Odstrániť spracované položky`"

#: ../../menu_descriptions/menu_batchqueue.rst:63
msgid "Remove items already processed from the current queue."
msgstr "Odstráni už spracované položky z aktuálneho frontu."

#: ../../menu_descriptions/menu_batchqueue.rst:65
msgid ":menuselection:`Queues --> Clear Queue` :kbd:`Ctrl+Shift+K`"
msgstr ":menuselection:`Fronty --> Vyprázdniť front` :kbd:`Ctrl+Shift+K`"

#: ../../menu_descriptions/menu_batchqueue.rst:67
msgid "Remove all items from the current queue."
msgstr "Odstráni všetky položky z aktuálneho frontu."

#: ../../menu_descriptions/menu_batchqueue.rst:69
msgid ":menuselection:`Queues --> Close` :kbd:`Ctrl+W`"
msgstr ":menuselection:`Fronty --> Zavrieť` :kbd:`Ctrl+W`"

#: ../../menu_descriptions/menu_batchqueue.rst:71
msgid "Close digiKam Batch Queue Manager."
msgstr "Zavrie digiKam Batch Queue Manager."

#: ../../menu_descriptions/menu_batchqueue.rst:74
msgid "The Tools Menu"
msgstr "Ponuka Nástroje"

#: ../../menu_descriptions/menu_batchqueue.rst:76
msgid ":menuselection:`Tools --> Move up`"
msgstr ":menuselection:`Nástroje --> Presunúť nahor`"

#: ../../menu_descriptions/menu_batchqueue.rst:78
msgid "Move the current selected item up in the **Assigned Tools** list."
msgstr ""
"Presunie aktuálne vybratú položku nahor v zozname **Priradených nástrojov**."

#: ../../menu_descriptions/menu_batchqueue.rst:80
msgid ":menuselection:`Tools --> Move down`"
msgstr ":menuselection:`Nástroje --> Presunúť nadol`"

#: ../../menu_descriptions/menu_batchqueue.rst:82
msgid "Move the current selected item down in the **Assigned Tools** list."
msgstr ""
"Presunie aktuálne vybratú položku nadol v zozname **Priradených nástrojov**."

#: ../../menu_descriptions/menu_batchqueue.rst:84
msgid ":menuselection:`Tools --> Remove tool`"
msgstr ":menuselection:`Nástroje --> Odstrániť nástroj`"

#: ../../menu_descriptions/menu_batchqueue.rst:86
msgid "Remove the current selected item from the **Assigned Tools** list."
msgstr ""
"Odstráni aktuálne vybratú položku zo zoznamu **Priradených nástrojov**."

#: ../../menu_descriptions/menu_batchqueue.rst:88
msgid ":menuselection:`Tools --> Clear List`"
msgstr ":menuselection:`Nástroje --> Vymazat zoznam`"

#: ../../menu_descriptions/menu_batchqueue.rst:90
msgid "Remove all items from the **Assigned Tools** list."
msgstr "Odstráni všetky položky zo zoznamu **Priradených nástrojov**."

#: ../../menu_descriptions/menu_batchqueue.rst:93
msgid "The View Menu"
msgstr "Ponuka Zobrazení"

#: ../../menu_descriptions/menu_batchqueue.rst:95
msgid ""
"**Full Screen Mode** option is the same entry available in :ref:`Main Window "
"<menu_mainfullscreen>`."
msgstr ""
"Možnosť **Režim celéj obrazovky** je rovnaká položka dostupná v :ref:"
"`Hlavnom okne <menu_mainfullscreen>`."

#: ../../menu_descriptions/menu_batchqueue.rst:98
msgid "The Settings Menu"
msgstr "Ponuka Nastavenia"

#: ../../menu_descriptions/menu_batchqueue.rst:100
msgid "See description from :ref:`Main Window <menu_mainsettings>` section."
msgstr "Pozrite popis v časti :ref:`Hlavného okna <menu_mainsettings>`."

#: ../../menu_descriptions/menu_batchqueue.rst:103
msgid "The Help Menu"
msgstr "Ponuka Pomocníka"

#: ../../menu_descriptions/menu_batchqueue.rst:105
msgid "See description from :ref:`Main Window <menu_mainhelp>` section."
msgstr "Pozrite popis v časti :ref:`Hlavného okna <menu_mainhelp>`."
